# ──────────────────────────────────────────
#  FLORIA — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
# ──────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=sua_senha_aqui
DB_NAME=floria

# Pool de conexões
DB_POOL_LIMIT=10        # Máximo de conexões simultâneas
DB_POOL_QUEUE=0         # 0 = sem limite na fila (waitForConnections)
DB_CONNECT_TIMEOUT=10000

# Segurança (JWT / Sessão — adapte conforme necessidade)
SESSION_SECRET=troque_por_uma_string_secreta_longa
