  <title>Floria — Plantas</title>
  <link rel="stylesheet" href="css/Vasos.css">
</head>
<body>

  <%- include("../partials/header") %>
  <%- include("../partials/nav") %>

  <main>
    <section class="page-title">
      <h1>Plantas</h1>
