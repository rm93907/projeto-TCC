                <img src="imagens/muda.png" alt="Muda de Comigo Ninguém Pode">
                <figcaption>
                  <h3>Muda de Comigo Ninguém Pode</h3>
                  <p class="price">R$ 211,25</p>
                </figcaption>
              </figure>
            </a>
            <footer class="card-footer">
              <button class="btn-comprar">Comprar</button>
            </footer>
          </article>
          </li>
          <li><article class="card">
            <a href="#">
              <figure>
                <img src="imagens/singonio.png" alt="Singônio (Syngonium)">
                <figcaption>
                  <h3>Singônio (Syngonium)</h3>
                  <p class="price">R$ 45,00</p>
                </figcaption>
              </figure>
            </a>
            <footer class="card-footer">
              <button class="btn-comprar">Comprar</button>
            </footer>
          </article>
          </li>
