                  <p class="price">R$ 120,00</p>
                </figcaption>
              </figure>
            </a>
            <footer class="card-footer">
              <button class="btn-comprar">Comprar</button>
            </footer>
          </article>
          </li>
          <li><article class="card">
            <a href="#">
              <figure>
                <img src="imagens/sansevieria.png" alt="Espada-de-São-Jorge">
                <figcaption>
                  <h3>Espada-de-São-Jorge</h3>
                  <p class="price">R$ 35,00</p>
