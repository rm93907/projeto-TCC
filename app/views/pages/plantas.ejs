              </figure>
            </a>
            <footer class="card-footer">
              <button class="btn-comprar">Comprar</button>
            </footer>
          </article>
          </li>
          <li><article class="card">
            <a href="#">
              <figure>
                <img src="imagens/philodendron.png" alt="Jiboia (Philodendron)">
                <figcaption>
                  <h3>Jiboia (Philodendron)</h3>
                  <p class="price">R$ 55,00</p>
                </figcaption>
              </figure>
            </a>
            <footer class="card-footer">
              <button class="btn-comprar">Comprar</button>
            </footer>
          </article>
          </li>
        </ul>
        <button class="carousel-btn" onclick="scrollCarousel(this,1)" aria-label="Próximo">&#8594;</button>
      </nav>
    </section>

