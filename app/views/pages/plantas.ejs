              <figure>
                <img src="imagens/baboda.jpg" alt="Babosa">
                <figcaption>
                  <h3>Babosa</h3>
                  <p class="price">R$ 116,25</p>
                </figcaption>
              </figure>
            </a>
            <footer class="card-footer">
